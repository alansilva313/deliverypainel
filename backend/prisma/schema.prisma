generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLATFORM_ADMIN
  OWNER
  MANAGER
  ATTENDANT
  KITCHEN
  DRIVER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  COMPLETED
  CANCELLED
  REJECTED
}

enum OrderChannel {
  PANEL
  WHATSAPP
  WEBSITE
  MANUAL
  API
}

enum DeliveryType {
  DELIVERY
  PICKUP
  DINE_IN
  SCHEDULED
}

enum PaymentMethod {
  PIX
  CASH
  CREDIT_CARD
  DEBIT_CARD
  ONLINE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Establishment {
  id                     String   @id @default(uuid())
  name                   String
  slug                   String   @unique
  email                  String?
  phone                  String?
  whatsapp               String?
  description            String?
  logoUrl                String?
  coverUrl               String?
  primaryColor           String   @default("#f97316")
  active                 Boolean  @default(true)
  acceptingOrders        Boolean  @default(true)
  minimumOrder           Decimal  @default(0) @db.Decimal(10, 2)
  averagePreparationTime Int      @default(30)
  timezone               String   @default("America/Sao_Paulo")
  deliveryEnabled        Boolean  @default(true)
  pickupEnabled          Boolean  @default(true)
  dineInEnabled          Boolean  @default(false)
  scheduledOrdersEnabled Boolean  @default(false)
  address                String?
  city                   String?
  state                  String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  users         User[]
  categories    Category[]
  products      Product[]
  customers     Customer[]
  orders        Order[]
  apiKeys       ApiKey[]
  coupons       Coupon[]
  deliveryZones DeliveryZone[]
}

model User {
  id              String         @id @default(uuid())
  establishmentId String?
  establishment   Establishment? @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  name            String
  email           String         @unique
  passwordHash    String
  role            UserRole       @default(OWNER)
  active          Boolean        @default(true)
  avatarUrl       String?
  lastLoginAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([establishmentId])
}

model Category {
  id              String        @id @default(uuid())
  establishmentId String
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  imageUrl        String?
  sortOrder       Int           @default(0)
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  products        Product[]

  @@unique([establishmentId, name])
  @@index([establishmentId])
}

model Product {
  id               String        @id @default(uuid())
  establishmentId  String
  establishment    Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  categoryId       String
  category         Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  name             String
  description      String?
  sku              String?
  price            Decimal       @db.Decimal(10, 2)
  promotionalPrice Decimal?      @db.Decimal(10, 2)
  costPrice        Decimal?      @db.Decimal(10, 2)
  available        Boolean       @default(true)
  featured         Boolean       @default(false)
  trackStock       Boolean       @default(false)
  stock            Int?
  preparationTime  Int?
  imageUrl         String?
  tags             String[]
  productType      String        @default("STANDARD") // STANDARD, PIZZA, COMBO, CUSTOM
  minFlavors       Int           @default(1)
  maxFlavors       Int           @default(1)
  pricingRule      String        @default("BASE") // BASE, HIGHEST_FLAVOR, AVERAGE_FLAVOR, SUM
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  orderItems    OrderItem[]
  modifierGroups ProductModifierGroup[]

  @@unique([establishmentId, sku])
  @@index([establishmentId])
  @@index([categoryId])
}

model ModifierGroup {
  id              String   @id @default(uuid())
  establishmentId String
  name            String
  minSelect       Int      @default(0)
  maxSelect       Int      @default(1)
  required        Boolean  @default(false)
  displayType     String   @default("CHECKBOX") // RADIO, CHECKBOX, QUANTITY, FLAVOR
  calculationType String   @default("ADD") // ADD, REPLACE, HIGHEST, AVERAGE
  freeQuantity    Int      @default(0)
  sortOrder       Int      @default(0)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  options  ModifierOption[]
  products ProductModifierGroup[]

  @@index([establishmentId])
}

model ModifierOption {
  id        String        @id @default(uuid())
  groupId   String
  group     ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name      String
  price     Decimal       @default(0) @db.Decimal(10, 2)
  active    Boolean       @default(true)
  sortOrder Int           @default(0)
  maxQuantity Int         @default(1)
  metadata    Json?
}

model ProductModifierGroup {
  productId String
  product   Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  groupId   String
  group     ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([productId, groupId])
}

model Customer {
  id              String        @id @default(uuid())
  establishmentId String
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  name            String
  phone           String
  email           String?
  birthDate       DateTime?
  notes           String?
  blocked         Boolean       @default(false)
  totalSpent      Decimal       @default(0) @db.Decimal(12, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  orders    Order[]
  addresses CustomerAddress[]

  @@unique([establishmentId, phone])
  @@index([establishmentId])
  @@index([phone])
}

model CustomerAddress {
  id           String   @id @default(uuid())
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label        String?
  zipCode      String
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String
  reference    String?
  primary      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders Order[]
}

model Order {
  id                 String          @id @default(uuid())
  establishmentId    String
  establishment      Establishment   @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  customerId         String
  customer           Customer        @relation(fields: [customerId], references: [id], onDelete: Restrict)
  addressId          String?
  address            CustomerAddress? @relation(fields: [addressId], references: [id])
  orderNumber        Int
  channel            OrderChannel    @default(API)
  status             OrderStatus     @default(PENDING)
  deliveryType       DeliveryType
  paymentMethod      PaymentMethod   @default(PIX)
  paymentStatus      PaymentStatus   @default(PENDING)
  subtotal           Decimal         @db.Decimal(10, 2)
  discount           Decimal         @default(0) @db.Decimal(10, 2)
  deliveryFee        Decimal         @default(0) @db.Decimal(10, 2)
  total              Decimal         @db.Decimal(10, 2)
  notes              String?
  cancellationReason String?
  scheduledFor       DateTime?
  estimatedAt        DateTime?
  idempotencyKey     String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  items   OrderItem[]
  history OrderStatusHistory[]

  @@unique([establishmentId, orderNumber])
  @@unique([establishmentId, idempotencyKey])
  @@index([establishmentId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id                  String   @id @default(uuid())
  orderId             String
  order               Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId           String
  product             Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  productNameSnapshot String
  unitPrice           Decimal  @db.Decimal(10, 2)
  quantity            Int
  subtotal            Decimal  @db.Decimal(10, 2)
  notes               String?
  modifiers           Json?
}

model OrderStatusHistory {
  id        String       @id @default(uuid())
  orderId   String
  order     Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  from      OrderStatus?
  to        OrderStatus
  origin    String
  note      String?
  createdAt DateTime     @default(now())
}

model Coupon {
  id              String        @id @default(uuid())
  establishmentId String
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  code            String
  description     String?
  discountType    String
  discountValue   Decimal       @db.Decimal(10, 2)
  minimumOrder    Decimal       @default(0) @db.Decimal(10, 2)
  maxUses         Int?
  uses            Int           @default(0)
  startsAt        DateTime?
  expiresAt       DateTime?
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([establishmentId, code])
}

model DeliveryZone {
  id               String        @id @default(uuid())
  establishmentId  String
  establishment    Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  name             String
  neighborhoods    String[]
  fee              Decimal       @db.Decimal(10, 2)
  minimumOrder     Decimal       @default(0) @db.Decimal(10, 2)
  estimatedMinutes Int           @default(45)
  active           Boolean       @default(true)
}

model ApiKey {
  id              String        @id @default(uuid())
  establishmentId String
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  name            String
  keyHash         String        @unique
  prefix          String
  active          Boolean       @default(true)
  permissions     String[]
  lastUsedAt      DateTime?
  expiresAt       DateTime?
  createdAt       DateTime      @default(now())

  @@index([establishmentId])
}
